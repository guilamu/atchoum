# Atchoum! Environment Variables

# Atmo Data API Credentials
# Get credentials from: https://admindata.atmo-france.org/inscription-api
VITE_ATMO_USERNAME=your_username_here
VITE_ATMO_PASSWORD=your_password_here

# Optional: API Rate Limiting
# VITE_ATMO_RATE_LIMIT_PER_MINUTE=60
# VITE_ATMO_RATE_LIMIT_PER_DAY=1000
